{
  "manifest_version": 3,
  "name": "LingText for YouTube",
  "version": "0.2.0",
  "description": "Lerne Englisch mit YouTube-Untertiteln. Synchronisiere mit deinem LingText-Vokabular.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://lingtext.de/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/content/youtube.tsx"]
    },
    {
      "matches": ["https://lingtext.de/*", "http://localhost:*/*"],
      "js": ["src/content/bridge.ts"]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
